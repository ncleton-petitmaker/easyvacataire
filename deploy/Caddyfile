easyvacataire.fr, www.easyvacataire.fr {
	# Supabase GoTrue auth (not /api/auth which is Next.js OTP)
	handle /auth/v1/* {
		reverse_proxy supabase-kong:8000
	}
	# Supabase PostgREST
	handle /rest/v1/* {
		reverse_proxy supabase-kong:8000
	}
	# Everything else → Next.js (including /api/auth/request-otp, /api/auth/verify-otp)
	handle {
		reverse_proxy nextjs-app:3000
	}
}

api.easyvacataire.fr {
	reverse_proxy evolution:8080
}
