############################################################
# UniPlanning VPS — Variables d'environnement
# Copier en .env et remplir les valeurs
############################################################

# --- Domaine ---
DOMAIN=uniplanning.example.com
SITE_URL=https://uniplanning.example.com
API_EXTERNAL_URL=https://uniplanning.example.com

# --- Supabase DB ---
POSTGRES_PASSWORD=CHANGEZ-MOI-mot-de-passe-fort
JWT_SECRET=CHANGEZ-MOI-minimum-32-caracteres-secret-jwt

# --- Supabase Keys ---
# Generer avec: node -e "console.log(require('jsonwebtoken').sign({role:'anon',iss:'supabase',iat:Math.floor(Date.now()/1000),exp:Math.floor(Date.now()/1000)+315360000},process.env.JWT_SECRET))"
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Next.js (passees a Coolify comme build args + env) ---
NEXT_PUBLIC_SUPABASE_URL=https://uniplanning.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://uniplanning.example.com
SUPABASE_SERVICE_ROLE_KEY=

# --- Evolution API ---
EVOLUTION_API_KEY=CHANGEZ-MOI-cle-evolution
EVOLUTION_DB_PASSWORD=CHANGEZ-MOI-evolution-db

# --- Evolution (pour Next.js) ---
EVOLUTION_API_URL=http://univ-evolution:8080
EVOLUTION_INSTANCE=univ-bot

# --- Mistral ---
MISTRAL_API_KEY=
