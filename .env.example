# =============================================================================
# EasyVacataire — Variables d'environnement
# =============================================================================
# Copiez ce fichier en .env.local et renseignez vos valeurs.
# Ne commitez JAMAIS le fichier .env.local !
#
# Dev local :
#   - Supabase : supabase start (CLI, ports 5435x)
#   - Evolution : docker compose up -d (port 8080)
#   - Next.js : npm run dev (port 3000)
#
# Production (VPS) :
#   - Voir deploy/.env.example
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# URL et clés disponibles via `supabase status` (dev local)
# ou dans le dashboard Supabase (production)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp)
# -----------------------------------------------------------------------------
# URL de l'instance Evolution API (docker compose up -d)
EVOLUTION_API_URL=http://localhost:8080
# Clé d'authentification (définie dans docker-compose.yml)
EVOLUTION_API_KEY=changeme
# Nom de l'instance WhatsApp dans Evolution
EVOLUTION_INSTANCE=univ-bot

# -----------------------------------------------------------------------------
# Mistral AI (optionnel)
# -----------------------------------------------------------------------------
# Clé API pour le LLM (chat agent) et les embeddings (RAG)
# Sans cette clé, le bot fonctionne en mode fallback (mots-clés)
# Obtenez une clé sur https://console.mistral.ai/
MISTRAL_API_KEY=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# URL publique de l'application (utilisée pour les liens dans les messages WhatsApp)
NEXT_PUBLIC_APP_URL=http://localhost:3000
